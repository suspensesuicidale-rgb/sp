function Test-UserPassword {
    param(
        [Parameter(Mandatory=$true)]
        [string]$Username,
        [Parameter(Mandatory=$true)]
        [System.Security.SecureString]$Password,
        [string]$DC = "DC01.TwojaDomena.local"
    )

    # Konwersja SecureString na zwykły tekst dla LDAP bind
    $BSTR = [System.Runtime.InteropServices.Marshal]::SecureStringToBSTR($Password)
    $PlainPassword = [System.Runtime.InteropServices.Marshal]::PtrToStringAuto($BSTR)

    $Path = "LDAP://$DC"
    $Entry = New-Object System.DirectoryServices.DirectoryEntry($Path, $Username, $PlainPassword, "Secure")

    try {
        $Entry.Bind()
        return $true # Hasło poprawne
    }
    catch {
        return $false # Hasło błędne lub inne problemy
    }
    finally {
        # Zawsze zwalniamy zasoby, niezależnie od wyniku
        $Entry.Dispose()
        [System.Runtime.InteropServices.Marshal]::ZeroFreeBSTR($BSTR)
    }
}




