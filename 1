# Dodaj bibliotekę obsługującą zarządzanie kontami
Add-Type -AssemblyName System.DirectoryServices.AccountManagement

# Ustawienia
$Domain = "TWOJA_DOMENA.LOCAL"
$Username = "login_uzytkownika"
$Password = "haslo_do_sprawdzenia"

# Utwórz kontekst domeny
$Context = New-Object System.DirectoryServices.AccountManagement.PrincipalContext([System.DirectoryServices.AccountManagement.ContextType]::Domain, $Domain)

# Spróbuj zweryfikować
$IsValid = $Context.ValidateCredentials($Username, $Password)

if ($IsValid) {
    Write-Host "Hasło jest poprawne!" -ForegroundColor Green
} else {
    Write-Host "Hasło jest błędne lub konto jest zablokowane." -ForegroundColor Red
}
